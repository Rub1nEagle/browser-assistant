LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o-mini

ANTHROPIC_API_KEY=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

MAX_STEPS=60
MAX_COST_USD=2.0

# When true, the agent stops to ask before any tool call that looks
# destructive (delete/send/pay/confirm/submit/archive — English + Russian).
# Reply 'yes' once, 'always' for the rest of the run, anything else cancels.
# Set false only for unattended runs in trusted environments.
CONFIRM_DESTRUCTIVE=true

BROWSER_PROFILE_DIR=./.browser-profile